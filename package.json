{
  "name": "jiaoben-baidi",
  "version": "1.0.0",
  "description": "Local Gemini batch image generation app",
  "main": "src/server/index.js",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch src/server/index.js",
    "dev:client": "vite --host 127.0.0.1",
    "start": "node src/server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:watch": "vitest",
    "package:mac": "node scripts/package-mac-app.js",
    "package:windows": "node scripts/package-windows.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@google/genai": "^2.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.14.0",
    "mime-types": "^3.0.2",
    "multer": "^2.1.1",
    "p-limit": "^7.3.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "undici": "^8.2.0",
    "uuid": "^14.0.0",
    "vite": "^8.0.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/adm-zip": "^0.5.8",
    "concurrently": "^9.2.1",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
